# Ignore everything by default
*

# Allow directories themselves
!fpga/
!cpu/
!gpu/
!software/

# Allow traversal into subdirectories
!fpga/**
!cpu/**
!gpu/**
!software/**

# Now re-ignore everything inside them
fpga/*
cpu/*
gpu/*
software/*

# Allow directories recursively
!fpga/**/
!cpu/**/
!gpu/**/
!software/**/

########################################
# Allowed file types in these dirs
########################################

# SystemVerilog
!fpga/**/*.sv
!fpga/**/*.svh
!cpu/**/*.sv
!cpu/**/*.svh
!gpu/**/*.sv
!gpu/**/*.svh

# C / C++
!fpga/**/*.c
!fpga/**/*.cpp
!fpga/**/*.cc
!fpga/**/*.h
!fpga/**/*.hpp

!cpu/**/*.c
!cpu/**/*.cpp
!cpu/**/*.cc
!cpu/**/*.h
!cpu/**/*.hpp

!gpu/**/*.c
!gpu/**/*.cpp
!gpu/**/*.cc
!gpu/**/*.h
!gpu/**/*.hpp

!software/**/*.c
!software/**/*.cpp
!software/**/*.cc
!software/**/*.h
!software/**/*.hpp

# CUDA
!software/**/*.cu

# Scripts
!fpga/**/*.py
!fpga/**/*.pl
!fpga/**/*.tcl
!fpga/**/*.sh
!fpga/**/*.dc

!cpu/**/*.py
!cpu/**/*.pl
!cpu/**/*.tcl
!cpu/**/*.sh
!cpu/**/*.dc

!gpu/**/*.py
!gpu/**/*.pl
!gpu/**/*.tcl
!gpu/**/*.sh
!gpu/**/*.dc

!software/**/*.py
!software/**/*.pl
!software/**/*.tcl
!software/**/*.sh
!software/**/*.dc

# Makefiles
!fpga/**/Makefile
!cpu/**/Makefile
!gpu/**/Makefile
!software/**/Makefile

# README files
!fpga/**/README
!fpga/**/README.md
!cpu/**/README
!cpu/**/README.md
!gpu/**/README
!gpu/**/README.md
!software/**/README
!software/**/README.md

# .gitignore files
!fpga/**/.gitignore
!cpu/**/.gitignore
!gpu/**/.gitignore
!software/**/.gitignore

# build artifacts
software/build/
